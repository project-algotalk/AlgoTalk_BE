<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.algotalk.userservice.repository.IUserInfoMapper">

    <select id="getNicknameByUserId"
            parameterType="UserInfoCommand"
            resultType="UserInfoCommand">
        SELECT NICKNAME
        FROM USERS
        WHERE USER_ID = #{userId}
          AND DELETED_YN = 'N'
    </select>

</mapper>
